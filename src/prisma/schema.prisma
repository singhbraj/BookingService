
generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "mysql"
}


model Booking {

id Int @id @default(autoincrement())
userId Int
hotelId Int
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt
bookingAmount Int
totalGuests Int
status BookingStatus

}

enum BookingStatus{
  PENDING
  CONFIRMED
  CANCELED
}